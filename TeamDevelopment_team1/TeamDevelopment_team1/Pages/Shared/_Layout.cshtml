<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — タスク管理 </title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- Navigation bar -->
    <nav class="navbar">
        <div class="navbar-inner">
            <a asp-page="/Todos/Index" class="navbar-brand" style="text-decoration: none;">
                <!-- Removed the entire SVG block -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2">
                    <path d="M9 11l3 3L22 4" />
                    <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" />
                </svg>
                <span style="font-size: 1rem; font-weight: bold; color: #064e3b;">TODO TASK APP</span>
            </a>
           <!-- <div class="navbar-links">
                <a asp-page="/Todos/Index"
                   class="navbar-link">All Tasks</a>
                <a asp-page="/Todos/Index"
                   asp-route-Filter="incomplete"
                   class="navbar-link">Incomplete</a>
                <a asp-page="/Todos/Index"
                   asp-route-Filter="complete"
                   class="navbar-link">Complete</a>
                <a asp-page="/Todos/Create"
                   class="btn btn-primary btn-sm">+ Add Task</a>
            </div> -->
        </div>
    </nav>

    <!-- Page content rendered here -->
    <main class="main-content">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="site-footer">
        <div class="footer-inner">
            タスク管理 — チーム開発タスク(野間、永野、デイネス)
        </div>
    </footer>

    <!-- jQuery and validation scripts (CDN) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
