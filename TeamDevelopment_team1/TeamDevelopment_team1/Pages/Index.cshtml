@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}
<style>
    .modern-btn-emerald {
        background-color: #f0fdf4;
        color: #16a34a;
        border: 1px solid #dcfce7;
        font-weight: 600;
    }

        .modern-btn-emerald:hover {
            background-color: #dcfce7;
            color: #15803d;
        }
</style>

<div>
    <h2>TODO APP</h2>

    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Id</th>
                <th>Title</th>
                <th>Detail</th>
                <th>Priority</th>
                <th>Due Date</th>
                <th>Is Completed</th>
                <th style="width: 150px;">Actions</th> <!-- Added header column for actions -->
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.ItemsList)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Title</td>
                    <td>@item.Detail</td>
                    <td>@item.PriorityLabel</td>
                    <td>@item.DueDate?.ToString("yyyy-MM-dd")</td>
                    <td>@item.IsCompleted</td>
                    <td>
                        <!-- Action Buttons -->
                        <a asp-page="/EditEmployee" asp-route-id="@item.Id" class="btn btn-sm modern-btn-emerald me-1" title="Edit">
                            Edit
                        </a>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this item?');">
                            <button type="submit" class="btn btn-sm modern-btn-emerald" title="Delete">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>