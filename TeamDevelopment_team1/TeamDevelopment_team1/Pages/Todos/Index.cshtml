@page
@model TeamDevelopment_team1.Pages.Todos.IndexModel
@using TeamDevelopment_team1.Models
@{
    ViewData["Title"] = "Task Board";
}

<div class="stats-grid" style="margin-bottom: 16px;">
    <h2 class="stat-label" style="font-size: 2rem; font-weight: 800; color: #0f172a; margin: 0; letter-spacing: -0.025em;">
        タスク管理
    </h2>
</div>

<!-- ── ステータスカード タスク管理 ────────────────────────────────────────── -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-label">合計タスク</div>
        <div class="stat-value">@Model.StatTotal</div>
    </div>
    <div class="stat-card stat-card--green">
        <div class="stat-label">完了済み</div>
        <div class="stat-value">@Model.StatCompleted</div>
    </div>
    <div class="stat-card @(Model.StatOverdue > 0 ? "stat-card--red" : "")">
        <div class="stat-label">期限間近：1
</div>
        <div class="stat-value">@Model.StatOverdue</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">進行中</div>
        <div class="stat-value">@(Model.StatTotal - Model.StatCompleted)</div>
    </div>
</div>

<!-- ── ツールバー：フィルタータブ＋追加ボタン ─────────────────── -->
<div class="toolbar">
    <div class="filter-tabs">
        <a asp-page="./Index" asp-route-Filter=""
           class="filter-tab @(string.IsNullOrEmpty(Model.Filter) ? "filter-tab--active" : "")">    
           全て
        </a>
        <a asp-page="./Index" asp-route-Filter="incomplete"
               class="filter-tab @(Model.Filter == "incomplete" ? "filter-tab--active" : "")">
        未完了
        </a>
        <a asp-page="./Index" asp-route-Filter="complete"
               class="filter-tab @(Model.Filter == "complete" ? "filter-tab--active" : "")">
            完了
        </a>
    </div>

    <a asp-page="./Create" class="btn btn-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5">
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
        </svg>
    タスク追加
    </a>
</div>

<!-- ── DB error message ──────────────────────────────────── -->
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <span asp-validation-summary="All"></span>
    </div>
}

<!-- ── Empty state ───────────────────────────────────────── -->
@if (!Model.Todos.Any())
{
    <div class="empty-state">
        <div class="empty-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2" />
                <line x1="9" y1="9" x2="15" y2="9" />
                <line x1="9" y1="12" x2="15" y2="12" />
                <line x1="9" y1="15" x2="12" y2="15" />
            </svg>
        </div>
        <p class="empty-title">No tasks found</p>
        <p class="empty-sub">
            @if (Model.Filter == "complete")
            {
                <text>No completed tasks yet.</text>
            }
            else if (Model.Filter == "incomplete")
            {
                <text>All caught up — no pending tasks!</text>
            }
            else
            {
                <text>Add your first task to get started.</text>
            }
        </p>
        <a asp-page="./Create" class="btn btn-primary" style="margin-top:1rem">
            Add First Task
        </a>
    </div>
}
else
{
    <!-- ── タスクテーブル ─────────────────────────────────────── -->
    <div class="table-wrap">
        <table class="todo-table">
            <thead>
                <tr>
                    <th style="width:42px">完了</th>
                    <th>タスク</th>
                    <th style="width:90px">優先度</th>
                    <th style="width:115px">期限</th>
                    <th style="width:140px">操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (TodoItem todo in Model.Todos)
                {
                    <!-- 行が期限切れの場合は赤背景になります -->
                    <tr class="todo-row
                        @(todo.IsCompleted ? "todo-row--done" : "")
                        @(todo.IsOverdue ? "todo-row--overdue" : "")">

                        <!-- ── トグルボタン ─────────────────── -->
                        <td class="td-check">
                            <form method="post">
                                <input type="hidden" name="id" value="@todo.Id" />
                                <button type="submit"
                                        asp-page-handler="Toggle"
                                        class="check-btn @(todo.IsCompleted ? "check-btn--done" : "")"
                                        title="@(todo.IsCompleted ? "Mark incomplete" : "Mark complete")">
                                    @if (todo.IsCompleted)
                                    {
                                        <!-- 完了時に表示されるチェックマークアイコン -->
                                        <svg width="12" height="12" viewBox="0 0 24 24"
                                             fill="none" stroke="currentColor" stroke-width="3">
                                            <polyline points="20 6 9 17 4 12" />
                                        </svg>
                                    }
                                </button>
                                @Html.AntiForgeryToken()
                            </form>
                        </td>

                        <!-- ── タスクタイトル＋詳細 ───────────── -->
                        <td class="td-title">
                            <span class="task-name @(todo.IsCompleted ? "task-name--done" : "")">
                                @todo.Title
                            </span>
                            @if (!string.IsNullOrWhiteSpace(todo.Detail))
                            {
                                <span class="task-detail">@todo.Detail</span>
                            }
                        </td>

                        <!-- ── 優先度バッジ ────────────────── -->
                        <td>
                            <span class="priority-badge @todo.PriorityBadgeClass">
                                @todo.PriorityLabel
                            </span>
                        </td>

                        <!-- ── Due date + overdue badge ──────── -->
                        <td class="td-date">
                            @if (todo.DueDate.HasValue)
                            {
                                <span class="@(todo.IsOverdue  ? "date-overdue" :
                                    todo.IsDueToday ? "date-today" :"date-normal")">
                                    @todo.DueDate.Value.ToString("MM/dd/yy")
                                </span>

                                @if (todo.IsOverdue)
                                {
                                    <span class="date-badge date-badge--overdue">Overdue</span>
                                }
                                else if (todo.IsDueToday)
                                {
                                    <span class="date-badge date-badge--today">Today</span>
                                }
                            }
                            else
                            {
                                <span class="date-none">—</span>
                            }
                        </td>

                        <!-- ── Edit + Delete buttons ─────────── -->
                        <td class="td-actions">
                            <a asp-page="./Edit"
                                   asp-route-id="@todo.Id"
                                   class="btn btn-sm btn-outline">
                                ✏️
                            </a>

                            <form method="post"
                                  style="display:inline"
                                  onsubmit="return confirm('Delete this task? It cannot be undone.')">
                                <input type="hidden" name="id" value="@todo.Id" />
                                <button type="submit"
                                        asp-page-handler="Delete"
                                        class="btn btn-sm btn-danger-outline">
                                    ❌
                                </button>
                                @Html.AntiForgeryToken()
                            </form>
                        </td>

                    </tr>
                }
            </tbody>
        </table>
    </div>
}
