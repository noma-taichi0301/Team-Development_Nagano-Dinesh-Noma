@page
@model TeamDevelopment_team1.Pages.Todos.EditModel
@{
    ViewData["Title"] = "タスクを編集";
}
<div class="form-container">

    <!-- ヘッダ -->
    <div class="form-header">
        <a asp-page="./Index" class="back-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.5">
                <polyline points="15 18 9 12 15 6" />
            </svg>
            リストに戻る
        </a>
        <h1 class="form-title">タスクを編集</h1>
        <p class="form-subtitle">編集中: <strong>@Model.TaskTitle</strong></p>
    </div>

    <!-- Form -->
    <form method="post" class="task-form">

        <!-- 重要: 非表示フィールドはPOSTを通じてTodoIdを転送します -->
        <!--これがないと、OnPost() はどの行を更新すればよいかわかりません。 -->
        <input type="hidden" asp-for="TodoId" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <!-- 期限日と優先度を横並びに表示 -->
        <div class="field-row">
            <div class="field">
                <label asp-for="Input.DueDate" class="field-label">期限日</label>
                <input asp-for="Input.DueDate" type="date" class="field-input" />
                <span asp-validation-for="Input.DueDate" class="field-error"></span>
            </div>

            <div class="field">
                <label asp-for="Input.Priority" class="field-label">優先度</label>
                <select asp-for="Input.Priority" class="field-input field-select">
                    <option value="3">🔴 高</option>
                    <option value="2">🟡 中</option>
                    <option value="1">🟢 低</option>
                </select>
                <span asp-validation-for="Input.Priority" class="field-error"></span>
            </div>
        </div>

        <!-- タスク名 -->
        <div class="field">
            <label asp-for="Input.Title" class="field-label">
                タスク名 <span class="required">*</span>
            </label>
            <input asp-for="Input.Title"
                   class="field-input"
                   maxlength="100"
                   autocomplete="off" />
            <span asp-validation-for="Input.Title" class="field-error"></span>
        </div>

        <!-- 詳細 -->
        <div class="field">
            <label asp-for="Input.Detail" class="field-label">詳細</label>
            <textarea asp-for="Input.Detail"
                      class="field-input field-textarea"
                      maxlength="1000"
                      rows="3"></textarea>
            <span asp-validation-for="Input.Detail" class="field-error"></span>
        </div>

        <!-- Due Date and Priority side by side -->
     <!--   <div class="field-row">
            <div class="field">
                <label asp-for="Input.DueDate" class="field-label">期限日</label>
                <input asp-for="Input.DueDate" type="date" class="field-input" />
                <span asp-validation-for="Input.DueDate" class="field-error"></span>
            </div>

            <div class="field">
                <label asp-for="Input.Priority" class="field-label">優先度</label>
                <select asp-for="Input.Priority" class="field-input field-select">
                    <option value="3">🔴 高</option>
                    <option value="2">🟡 中</option>
                    <option value="1">🟢 低</option>
                </select>
                <span asp-validation-for="Input.Priority" class="field-error"></span>
            </div>
        </div>

        -->
        <!-- ボタン -->
        <div class="form-actions">
            <a asp-page="./Index" class="btn btn-outline">キャンセル</a>
            <button type="submit" class="btn btn-primary">変更を保存</button>
        </div>

    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}